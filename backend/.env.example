# NeuroCare Backend Environment Variables
# Copy this file to .env and fill in real values for local development.

# Flask
FLASK_ENV=development
# Use a long random string in production. You can generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=please-generate-a-long-random-string-here-at-least-32-chars
JWT_SECRET_KEY=please-generate-another-long-random-string-here-32chars

# SQLite database file (relative to backend/)
DATABASE_URL=sqlite:///neurocare.db

# CORS - frontend URL(s), comma separated.
#
# Accepted values:
#   *                          - allow any origin (simplest, fine for a student demo)
#   https://a.com,https://b.com - explicit allow-list
#   https://*.vercel.app       - wildcard (handles Vercel preview deployments)
#
# Default (when unset) is permissive - so the deployed frontend works even
# if this env var is forgotten on Railway.
CORS_ORIGINS=*

# Firebase Admin SDK (optional, for Google Sign-In verification)
# Paste the absolute path to your service account JSON, or leave empty
# to disable Google Sign-In on the server.
FIREBASE_CREDENTIALS_PATH=
